<Window x:Class="Enfolderer.App.Lands.LandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lands Viewer" Height="850" Width="1400" MinWidth="900" MinHeight="500"
        Background="{Binding PageBrush}" ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DataTemplate x:Key="LandSlotTemplate">
            <Border x:Name="RootBorder" Margin="4" CornerRadius="6" BorderThickness="2" Background="#222"
                    SnapsToDevicePixels="True" Cursor="Hand"
                    MouseLeftButtonUp="LandSlot_Click"
                    ToolTip="{Binding Tooltip}">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="BorderColor" Color="#444" />
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!-- Card image -->
                    <Border Grid.Row="0" Margin="3" CornerRadius="8" Background="Transparent" SnapsToDevicePixels="True">
                        <Image Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                               Source="{Binding ImageSource}" SnapsToDevicePixels="True" />
                    </Border>
                    <!-- Owned badge (top-left) -->
                    <Border Grid.Row="0" Background="#AA000000" CornerRadius="4" Padding="4,1"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6"
                            Visibility="{Binding IsOwned, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="✓ OWNED" FontSize="11" Foreground="#66DD66" FontWeight="Bold" />
                    </Border>
                    <!-- Card info -->
                    <StackPanel Grid.Row="1" Margin="2">
                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="White"
                                   HorizontalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" />
                        <TextBlock FontSize="10" Foreground="#CCC" HorizontalAlignment="Center">
                            <Run Text="{Binding Set, Mode=OneTime}" />
                            <Run Text=" #" />
                            <Run Text="{Binding CollectorNumber, Mode=OneTime}" />
                        </TextBlock>
                        <TextBlock Text="{Binding Artist}" FontSize="9" Foreground="#999"
                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsOwned}" Value="True">
                    <Setter TargetName="RootBorder" Property="BorderBrush" Value="#66DD66" />
                    <Setter TargetName="RootBorder" Property="BorderThickness" Value="3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOwned}" Value="False">
                    <Setter TargetName="RootBorder" Property="Opacity" Value="0.6" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="70" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="FontSize" Value="10" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Top toolbar -->
        <Grid DockPanel.Dock="Top" Margin="8">
            <WrapPanel VerticalAlignment="Center">
                <Button Style="{StaticResource NavButtonStyle}" Content="⏪ Binder" Command="{Binding PrevBinderCommand}" />
                <Button Style="{StaticResource NavButtonStyle}" Content="⏮ First" Command="{Binding FirstCommand}" />
                <Button Style="{StaticResource NavButtonStyle}" Content="◀ Prev" Command="{Binding PrevCommand}" />
                <Border VerticalAlignment="Center" Margin="8,0" Padding="0" Width="420">
                    <TextBlock Text="{Binding PageDisplay}" FontSize="14" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" />
                </Border>
                <Button Style="{StaticResource NavButtonStyle}" Content="Next ▶" Command="{Binding NextCommand}" />
                <Button Style="{StaticResource NavButtonStyle}" Content="Last ⏭" Command="{Binding LastCommand}" />
                <Button Style="{StaticResource NavButtonStyle}" Content="Binder ⏩" Command="{Binding NextBinderCommand}" />
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Set:" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox x:Name="FilterSetBox" Width="60" Text="{Binding FilterSet, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Name:" Foreground="#CCC" VerticalAlignment="Center" Margin="8,0,4,0" />
                    <TextBox x:Name="FilterNameBox" Width="100" Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </WrapPanel>
        </Grid>
        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}" />
            </StatusBarItem>
        </StatusBar>
        <!-- Two-page spread with spine -->
        <Grid Margin="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Left Page -->
            <ItemsControl Grid.Column="0" ItemsSource="{Binding LeftSlots}" ItemTemplate="{StaticResource LandSlotTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <!-- Spine -->
            <Grid Grid.Column="1">
                <Rectangle Width="30" Fill="#333" RadiusX="6" RadiusY="6" HorizontalAlignment="Center" />
            </Grid>
            <!-- Right Page -->
            <ItemsControl Grid.Column="2" ItemsSource="{Binding RightSlots}" ItemTemplate="{StaticResource LandSlotTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </DockPanel>
</Window>
